
<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:c="using:LoadingIndicators.Avalonia">

    <Design.PreviewWith>
        <Border Width="256" Height="256"
                Background="#333333">

            <c:LoadingIndicator Foreground="Chartreuse"
                                BorderBrush="DarkRed"
                                BorderThickness="1"
                                Theme="{DynamicResource ArcGrow}"
                                IsActive="True"
                                Mode="ArcGrow"
                                SpeedRatio="1" />
        </Border>
    </Design.PreviewWith>

    <ControlTheme x:Key="ArcGrow" TargetType="c:LoadingIndicator">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#CC119EDA" />
        <Setter Property="Width" Value="{Binding $parent[c:LoadingIndicator].Bounds.Width}" />
        <Setter Property="Height" Value="{Binding $parent[c:LoadingIndicator].Bounds.Height}" />
        <Setter Property="MinWidth" Value="32" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="IsHitTestVisible" Value="False" />
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border x:Name="PART_Border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        IsVisible="{TemplateBinding IsActive}"
                        IsHitTestVisible="{TemplateBinding IsHitTestVisible}"
                        ClipToBounds="{TemplateBinding ClipToBounds}">

                    <Border.Styles>
                        <Style Selector="Viewbox">
                            <Setter Property="Width" Value="{TemplateBinding Width}" />
                            <Setter Property="Height" Value="{TemplateBinding Height}" />
                            <Setter Property="Opacity" Value="0.7" />
                            <Setter Property="StretchDirection" Value="Both" />
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.5" ScaleY="0.5" />
                                </Setter.Value>
                            </Setter>
                        </Style>

                        <Style Selector="Arc">
                            <Setter Property="Margin" Value="5" />
                            <Setter Property="MinWidth" Value="{TemplateBinding MinWidth}" />
                            <Setter Property="MinHeight" Value="{TemplateBinding MinHeight}" />
                            <Setter Property="StrokeThickness" Value="2" />
                            <Setter Property="StrokeLineCap" Value="Round" />
                        </Style>
                    </Border.Styles>

                    <Viewbox>
                        <Viewbox.Styles>
                            <Style Selector="c|LoadingIndicator:inactive /template/ .InnerSpin" />
                            <Style Selector="c|LoadingIndicator:inactive /template/ .OuterSpin" />

                            <Style Selector="c|LoadingIndicator:active /template/ Panel.OuterSpin">
                              <Style.Animations>
                                    <Animation Duration="0:0:3.000"
                                               IterationCount="Infinite"
                                               SpeedRatio="{Binding $parent[c:LoadingIndicator].SpeedRatio}">

                                        <KeyFrame Cue="0%">
                                            <Setter Property="RotateTransform.Angle" Value="90" />
                                        </KeyFrame>

                                        <KeyFrame Cue="100%">
                                            <Setter Property="RotateTransform.Angle" Value="450" />
                                        </KeyFrame>
                                    </Animation>
                                </Style.Animations>
                            </Style>

                            <Style Selector="c|LoadingIndicator:active /template/ Arc.InnerSpin">
                                <Style.Animations>
                                    <Animation Duration="0:0:3.000"
                                               IterationCount="Infinite"
                                               SpeedRatio="{Binding $parent[c:LoadingIndicator].SpeedRatio}">
                                        
                                        <KeyFrame Cue="0%">
                                            <Setter Property="RotateTransform.Angle" Value="0"/>
                                        </KeyFrame>
                                        
                                        <KeyFrame Cue="100%">
                                            <Setter Property="RotateTransform.Angle" Value="84"/>
                                        </KeyFrame>
                                    </Animation>

                                    <Animation Duration="0:0:3.000"
                                               IterationCount="Infinite"
                                               Easing="CubicEaseInOut"
                                               SpeedRatio="{Binding $parent[c:LoadingIndicator].SpeedRatio}">

                                        <KeyFrame Cue="0%">
                                            <Setter Property="SweepAngle" Value="24"/>
                                        </KeyFrame>

                                        <KeyFrame Cue="50%">
                                            <Setter Property="SweepAngle" Value="300"/>
                                        </KeyFrame>

                                        <KeyFrame Cue="100%">
                                            <Setter Property="SweepAngle" Value="24"/>
                                        </KeyFrame>
                                    </Animation>

                                    <Animation Duration="0:0:3.0"
                                               IterationCount="Infinite"
                                               Easing="CubicEaseInOut"
                                               SpeedRatio="{Binding $parent[c:LoadingIndicator].SpeedRatio}">

                                        <KeyFrame Cue="0%">
                                            <Setter Property="StartAngle" Value="-135"/>
                                        </KeyFrame>

                                        <KeyFrame Cue="50%">
                                            <Setter Property="StartAngle" Value="-135"/>
                                        </KeyFrame>

                                        <KeyFrame Cue="100%">
                                            <Setter Property="StartAngle" Value="141"/>
                                        </KeyFrame>
                                    </Animation>
                                </Style.Animations>
                            </Style>
                        </Viewbox.Styles>

                        <Panel Classes="OuterSpin">
                            <Arc Classes="InnerSpin"
                                 Stroke="{TemplateBinding Foreground}"
                                 StrokeThickness="{TemplateBinding Thickness}"
                                 StartAngle="-135"
                                 SweepAngle="24" />
                        </Panel>
                    </Viewbox>
                </Border>
            </ControlTemplate>
        </Setter>
    </ControlTheme>
</ResourceDictionary>